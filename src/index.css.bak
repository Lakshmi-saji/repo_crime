/* ═══════════════════════════════════════════════════════════════
   Smart Crime Management System — Vibrant Glassmorphism UI
═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap');

*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  /* Rich, deep dark backgrounds */
  --bg-base: #050814;
  --bg-primary: #0a0f25;
  --bg-secondary: rgba(15, 23, 42, 0.7);
  --bg-card: rgba(20, 27, 49, 0.65);
  --bg-card-hover: rgba(28, 38, 69, 0.85);

  /* Vibrant Accents */
  --accent: #6366f1;
  --accent-light: #8b5cf6;
  --accent-glow: rgba(99, 102, 241, 0.4);
  --cyan: #06b6d4;
  --cyan-light: rgba(6, 182, 212, 0.2);
  --red: #f43f5e;
  --red-light: rgba(244, 63, 94, 0.2);
  --yellow: #f59e0b;
  --yellow-light: rgba(245, 158, 11, 0.2);
  --green: #10b981;
  --green-light: rgba(16, 185, 129, 0.2);
  --pink: #ec4899;
  --pink-light: rgba(236, 72, 153, 0.2);

  /* Borders & Glassmorphism */
  --border: rgba(255, 255, 255, 0.08);
  --border-glow: rgba(139, 92, 246, 0.5);
  --glass-blur: blur(16px);
  --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);

  /* Typography */
  --text-primary: #f8fafc;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;

  --sidebar-w: 280px;
  --radius: 14px;
  --radius-lg: 20px;
  --radius-xl: 30px;
  --shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
  --shadow-glow: 0 0 40px rgba(249, 115, 22, 0.25);
}

html,
body,
#root {
  height: 100%;
  font-family: 'Outfit', sans-serif;
  background: var(--bg-base);
  color: var(--text-primary);
  line-height: 1.6;
  overflow: hidden;
}

/* ─── ANIMATED BACKGROUND WRAPPER ───────────────────────────── */
body::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 50% 50%, rgba(99, 102, 241, 0.15), transparent 40%),
    radial-gradient(circle at 80% 20%, rgba(6, 182, 212, 0.1), transparent 30%),
    radial-gradient(circle at 20% 80%, rgba(236, 72, 153, 0.08), transparent 40%);
  animation: pulseBg 20s infinite alternate;
  z-index: -1;
  pointer-events: none;
}

@keyframes pulseBg {
  0% {
    transform: scale(1) translate(0, 0);
  }

  50% {
    transform: scale(1.05) translate(2%, 2%);
  }

  100% {
    transform: scale(1) translate(-2%, -2%);
  }
}

@keyframes floatUp {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }

  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ─── SCROLLBAR ─────────────────────────────────────────────── */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-primary);
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 99px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent);
}

/* ─── LAYOUT ────────────────────────────────────────────────── */
.app-layout {
  display: flex;
  height: 100vh;
  overflow: hidden;
  background: transparent;
}

.main-content {
  flex: 1;
  overflow-y: auto;
  padding: 40px;
  background: rgba(10, 15, 37, 0.4);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
}

/* ─── GLASS CARDS ───────────────────────────────────────────── */
.card {
  background: var(--bg-card);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 28px;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: var(--glass-shadow);
  position: relative;
  overflow: hidden;
  animation: floatUp 0.5s ease backwards;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.03), transparent);
  transform: skewX(-20deg);
  transition: 0.5s;
}

.card:hover {
  border-color: var(--border-glow);
  transform: translateY(-5px);
  box-shadow: var(--shadow-glow);
}

.card:hover::before {
  left: 150%;
}

.stat-card {
  background: var(--bg-card);
  backdrop-filter: var(--glass-blur);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: var(--glass-shadow);
  animation: floatUp 0.5s ease backwards;
}

.stat-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: var(--border-glow);
  box-shadow: 0 15px 30px rgba(99, 102, 241, 0.2);
}

.stat-icon {
  width: 64px;
  height: 64px;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.01));
  border: 1px solid var(--border);
  box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.02);
}

.stat-info .label {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.stat-info .value {
  font-size: 34px;
  font-weight: 800;
  background: linear-gradient(135deg, #fff, var(--text-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ─── FORMS ─────────────────────────────────────────────────── */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  margin-left: 4px;
}

.form-control {
  background: rgba(0, 0, 0, 0.2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-primary);
  font-family: inherit;
  font-size: 15px;
  padding: 14px 18px;
  outline: none;
  transition: all 0.3s ease;
  width: 100%;
  backdrop-filter: blur(8px);
}

.form-control:focus {
  border-color: var(--accent);
  background: rgba(99, 102, 241, 0.05);
  box-shadow: 0 0 0 4px var(--accent-glow);
  transform: translateY(-1px);
}

.form-control::placeholder {
  color: var(--text-muted);
}

select.form-control {
  cursor: pointer;
  appearance: none;
}

select.form-control option {
  background: var(--bg-card);
  color: #fff;
}

textarea.form-control {
  resize: vertical;
  min-height: 120px;
}

/* ─── BUTTONS ───────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 12px 24px;
  border: none;
  border-radius: var(--radius);
  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.5px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  text-decoration: none;
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(rgba(255, 255, 255, 0.2), transparent);
  opacity: 0;
  transition: 0.3s;
}

.btn:hover::after {
  opacity: 1;
}

.btn:active {
  transform: scale(0.96);
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent), var(--accent-light));
  color: #fff;
  box-shadow: 0 4px 15px var(--accent-glow);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px var(--accent-glow);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-primary);
  border: 1px solid var(--border);
  backdrop-filter: blur(4px);
}

.btn-secondary:hover {
  border-color: rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.1);
  transform: translateY(-2px);
}

.btn-danger {
  background: linear-gradient(135deg, #e11d48, #be123c);
  color: #fff;
  box-shadow: 0 4px 15px var(--red-light);
}

.btn-danger:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px var(--red-light);
}

.btn-success {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  box-shadow: 0 4px 15px var(--green-light);
}

.btn-success:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px var(--green-light);
}

.btn-sm {
  padding: 8px 16px;
  font-size: 13px;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  pointer-events: none;
}

/* ─── BADGES / STATUS ───────────────────────────────────────── */
.badge {
  padding: 5px 14px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
  backdrop-filter: blur(4px);
  border: 1px solid transparent;
}

.badge-pending {
  background: var(--yellow-light);
  color: var(--yellow);
  border-color: rgba(245, 158, 11, 0.3);
}

.badge-investigating {
  background: var(--cyan-light);
  color: var(--cyan);
  border-color: rgba(6, 182, 212, 0.3);
  box-shadow: 0 0 15px var(--cyan-light);
}

.badge-closed {
  background: var(--green-light);
  color: var(--green);
  border-color: rgba(16, 185, 129, 0.3);
}

.badge-alert {
  background: var(--red-light);
  color: var(--red);
  border-color: rgba(244, 63, 94, 0.3);
  animation: pulseAlert 2s infinite;
}

.badge-info {
  background: var(--accent-glow);
  color: var(--accent-light);
  border-color: rgba(139, 92, 246, 0.3);
}

.badge-admin {
  background: rgba(236, 72, 153, 0.15);
  color: var(--pink);
  border-color: rgba(236, 72, 153, 0.3);
}

.badge-officer {
  background: var(--cyan-light);
  color: var(--cyan);
  border-color: rgba(6, 182, 212, 0.3);
}

.badge-citizen {
  background: var(--green-light);
  color: var(--green);
  border-color: rgba(16, 185, 129, 0.3);
}

@keyframes pulseAlert {
  0% {
    box-shadow: 0 0 0 0 var(--red-light);
  }

  70% {
    box-shadow: 0 0 0 10px transparent;
  }

  100% {
    box-shadow: 0 0 0 0 transparent;
  }
}

/* ─── TABLE ─────────────────────────────────────────────────── */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(8px);
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead tr {
  background: rgba(255, 255, 255, 0.03);
  border-bottom: 2px solid rgba(255, 255, 255, 0.05);
}

thead th {
  padding: 16px 20px;
  text-align: left;
  font-size: 13px;
  font-weight: 700;
  color: var(--text-secondary);
  letter-spacing: 1px;
  text-transform: uppercase;
}

tbody tr {
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  transition: all 0.2s;
}

tbody tr:hover {
  background: rgba(255, 255, 255, 0.05);
  transform: scale(1.001);
}

tbody td {
  padding: 18px 20px;
  font-size: 15px;
  font-weight: 500;
}

/* ─── PAGE HEADER ───────────────────────────────────────────── */
.page-header {
  margin-bottom: 36px;
  animation: floatUp 0.6s ease backwards;
}

.page-header h1 {
  font-size: 32px;
  font-weight: 900;
  background: linear-gradient(to right, #fff, var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -0.5px;
}

.page-header p {
  color: var(--text-secondary);
  font-size: 16px;
  margin-top: 6px;
  font-weight: 400;
}

/* ─── GRID ──────────────────────────────────────────────────── */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.grid-auto {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px;
}

/* ─── FORM GRID ─────────────────────────────────────────────── */
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.form-grid .full {
  grid-column: 1 / -1;
}

/* ─── AUTH PAGES ────────────────────────────────────────────── */
.auth-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Abstract Shapes for Auth */
.auth-container::before,
.auth-container::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.6;
  z-index: -1;
  animation: floatShape 10s infinite alternate;
}

.auth-container::before {
  width: 400px;
  height: 400px;
  background: var(--accent);
  top: -100px;
  left: -100px;
}

.auth-container::after {
  width: 300px;
  height: 300px;
  background: var(--cyan);
  bottom: -50px;
  right: -50px;
  animation-delay: -5s;
}

@keyframes floatShape {
  0% {
    transform: translate(0, 0) scale(1);
  }

  100% {
    transform: translate(50px, 50px) scale(1.1);
  }
}

.auth-card {
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-xl);
  padding: 50px 44px;
  width: 100%;
  max-width: 480px;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  animation: floatUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) backwards;
}

.auth-logo {
  text-align: center;
  margin-bottom: 36px;
}

.auth-logo .shield {
  width: 72px;
  height: 72px;
  background: linear-gradient(135deg, var(--accent), var(--cyan));
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34px;
  margin: 0 auto 20px;
  box-shadow: 0 10px 30px var(--cyan-light);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.auth-logo h2 {
  font-size: 26px;
  font-weight: 900;
  letter-spacing: -0.5px;
}

.auth-logo p {
  font-size: 15px;
  color: var(--text-secondary);
  margin-top: 6px;
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.auth-footer {
  text-align: center;
  margin-top: 28px;
  font-size: 14px;
  color: var(--text-secondary);
}

.auth-footer a {
  color: var(--cyan);
  text-decoration: none;
  font-weight: 700;
  transition: color 0.2s;
}

.auth-footer a:hover {
  color: #fff;
  text-decoration: underline;
}

/* ─── SIDEBAR ───────────────────────────────────────────────── */
.sidebar {
  width: var(--sidebar-w);
  background: rgba(10, 15, 37, 0.5);
  backdrop-filter: blur(20px);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow-y: auto;
  flex-shrink: 0;
  box-shadow: 5px 0 30px rgba(0, 0, 0, 0.2);
}

.sidebar-logo {
  padding: 30px 24px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
  gap: 14px;
}

.sidebar-logo .logo-icon {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, var(--accent), var(--cyan));
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
}

.sidebar-logo .logo-text {
  font-size: 16px;
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -0.5px;
}

.sidebar-logo .logo-sub {
  font-size: 11px;
  color: var(--text-secondary);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 2px;
}

.sidebar-nav {
  flex: 1;
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.sidebar-section-title {
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1.5px;
  color: rgba(255, 255, 255, 0.3);
  text-transform: uppercase;
  padding: 16px 14px 8px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 16px;
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--text-secondary);
  font-size: 15px;
  font-weight: 600;
  transition: all 0.3s;
  position: relative;
}

.nav-link:hover {
  background: rgba(255, 255, 255, 0.05);
  color: #fff;
  transform: translateX(4px);
}

.nav-link.active {
  background: linear-gradient(90deg, rgba(99, 102, 241, 0.15), transparent);
  color: var(--accent-light);
  font-weight: 700;
  border-left: 3px solid var(--accent);
}

.nav-link .icon {
  font-size: 20px;
  flex-shrink: 0;
  transition: transform 0.3s;
}

.nav-link:hover .icon {
  transform: scale(1.1);
  color: var(--cyan);
}

.nav-link.active .icon {
  color: var(--accent-light);
}

.sidebar-footer {
  padding: 20px;
  border-top: 1px solid rgba(255, 255, 255, 0.03);
}

.user-pill {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 16px;
  border-radius: var(--radius-lg);
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s;
}

.user-pill:hover {
  background: rgba(0, 0, 0, 0.5);
  border-color: rgba(255, 255, 255, 0.1);
}

.user-pill .avatar {
  width: 40px;
  height: 40px;
  border-radius: 99px;
  background: linear-gradient(135deg, var(--accent), var(--pink));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 800;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 4px 10px rgba(236, 72, 153, 0.3);
}

.user-pill .user-info {
  flex: 1;
  min-width: 0;
}

.user-pill .user-name {
  font-size: 14px;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-pill .user-role {
  font-size: 12px;
  color: var(--accent-light);
  font-weight: 600;
  text-transform: capitalize;
}

/* ─── NAVBAR ────────────────────────────────────────────────── */
.topbar {
  height: 76px;
  background: rgba(10, 15, 37, 0.4);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.topbar-title {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 0.5px;
  opacity: 0.9;
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

/* ─── NOTIFICATION BELL ─────────────────────────────────────── */
.notif-btn {
  position: relative;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border);
  border-radius: 50%;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 20px;
  color: var(--text-primary);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.notif-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(1.1) rotate(5deg);
  color: var(--cyan);
  border-color: var(--cyan-light);
}

.notif-badge {
  position: absolute;
  top: -2px;
  right: -2px;
  background: var(--red);
  color: #fff;
  font-size: 11px;
  font-weight: 800;
  width: 20px;
  height: 20px;
  border-radius: 99px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 10px var(--red-light);
  border: 2px solid var(--bg-card);
}

.notif-panel {
  position: absolute;
  top: 70px;
  right: 40px;
  z-index: 100;
  width: 380px;
  background: rgba(20, 27, 49, 0.85);
  backdrop-filter: blur(24px);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  max-height: 500px;
  overflow-y: auto;
  animation: floatUp 0.3s ease backwards;
}

.notif-header {
  padding: 18px 24px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  font-weight: 800;
  font-size: 15px;
}

.notif-item {
  padding: 16px 24px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  cursor: pointer;
  transition: all 0.2s;
}

.notif-item:hover {
  background: rgba(255, 255, 255, 0.04);
  padding-left: 28px;
}

.notif-item.unread {
  background: rgba(99, 102, 241, 0.08);
  border-left: 3px solid var(--accent);
}

.notif-item .notif-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 4px;
  color: #fff;
}

.notif-item .notif-msg {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.notif-item .notif-time {
  font-size: 11px;
  color: var(--accent-light);
  margin-top: 8px;
  font-weight: 600;
}

.notif-empty {
  padding: 40px;
  text-align: center;
  color: var(--text-muted);
  font-size: 15px;
  font-weight: 500;
}

/* ─── MODAL ─────────────────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.modal {
  background: rgba(20, 27, 49, 0.85);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-xl);
  padding: 40px;
  width: 100%;
  max-width: 600px;
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  max-height: 90vh;
  overflow-y: auto;
  animation: floatUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) backwards;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30px;
}

.modal-header h3 {
  font-size: 22px;
  font-weight: 800;
  background: linear-gradient(135deg, #fff, var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.modal-close {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid transparent;
  color: var(--text-secondary);
  font-size: 20px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}

.modal-close:hover {
  background: rgba(244, 63, 94, 0.1);
  color: var(--red);
  border-color: rgba(244, 63, 94, 0.3);
  transform: rotate(90deg);
}

/* ─── UPLOAD ────────────────────────────────────────────────── */
.upload-area {
  border: 2px dashed rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-lg);
  padding: 40px;
  text-align: center;
  background: rgba(0, 0, 0, 0.2);
  cursor: pointer;
  transition: all 0.3s;
}

.upload-area:hover {
  border-color: var(--cyan);
  background: rgba(6, 182, 212, 0.05);
  transform: translateY(-2px);
  box-shadow: inset 0 0 20px rgba(6, 182, 212, 0.1);
}

.upload-area.dragover {
  border-color: var(--cyan);
  background: rgba(6, 182, 212, 0.15);
  border-style: solid;
  box-shadow: 0 0 30px var(--cyan-light);
}

.upload-area .u-icon {
  font-size: 40px;
  margin-bottom: 16px;
  color: var(--text-secondary);
  transition: 0.3s;
}

.upload-area:hover .u-icon {
  color: var(--cyan);
  transform: scale(1.1);
}

.upload-area p {
  font-size: 15px;
  font-weight: 500;
  color: #fff;
}

.progress-bar {
  background: rgba(0, 0, 0, 0.5);
  border-radius: 99px;
  height: 8px;
  margin-top: 20px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--cyan), var(--pink));
  border-radius: 99px;
  transition: width 0.3s ease-out;
  background-size: 200% auto;
  animation: shine 2s linear infinite;
}

@keyframes shine {
  to {
    background-position: 200% center;
  }
}

/* ─── ALERTS ────────────────────────────────────────────────── */
.alert {
  padding: 16px 20px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 12px;
  backdrop-filter: blur(8px);
  animation: floatUp 0.3s ease;
}

.alert-error {
  background: rgba(244, 63, 94, 0.15);
  color: #ffe4e6;
  border: 1px solid rgba(244, 63, 94, 0.4);
  box-shadow: 0 4px 20px rgba(244, 63, 94, 0.2);
}

.alert-success {
  background: rgba(16, 185, 129, 0.15);
  color: #d1fae5;
  border: 1px solid rgba(16, 185, 129, 0.4);
  box-shadow: 0 4px 20px rgba(16, 185, 129, 0.2);
}

.alert-info {
  background: rgba(6, 182, 212, 0.15);
  color: #cffafe;
  border: 1px solid rgba(6, 182, 212, 0.4);
  box-shadow: 0 4px 20px rgba(6, 182, 212, 0.2);
}

/* ─── UTILITIES ─────────────────────────────────────────────── */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gap-8 {
  gap: 8px;
}

.gap-12 {
  gap: 12px;
}

.gap-16 {
  gap: 16px;
}

.mt-8 {
  margin-top: 8px;
}

.mt-16 {
  margin-top: 16px;
}

.mt-24 {
  margin-top: 24px;
}

.mb-16 {
  margin-bottom: 16px;
}

.mb-24 {
  margin-bottom: 24px;
}

.text-muted {
  color: var(--text-secondary);
  font-size: 14px;
}

.text-center {
  text-align: center;
}

.w-full {
  width: 100%;
}

/* ─── LOADER ────────────────────────────────────────────────── */
.loader-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300px;
}

.spinner {
  width: 50px;
  height: 50px;
  border: 4px solid rgba(255, 255, 255, 0.05);
  border-top-color: var(--cyan);
  border-right-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
  box-shadow: 0 0 20px var(--cyan-light);
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ─── RESPONSIVE ────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .sidebar {
    width: 240px;
  }

  .main-content {
    padding: 30px;
  }
}

@media (max-width: 768px) {
  .sidebar {
    display: none;
  }

  .main-content {
    padding: 20px;
    backdrop-filter: none;
    background: transparent;
  }

  .grid-2,
  .grid-3,
  .grid-4,
  .grid-auto {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .auth-card {
    padding: 30px 24px;
    margin: 20px;
    border-radius: var(--radius-lg);
    backdrop-filter: blur(10px);
  }

  .topbar {
    padding: 0 20px;
    height: 60px;
  }
}